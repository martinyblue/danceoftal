{
  "name": "danceoftal-local-manager",
  "version": "0.4.1",
  "private": true,
  "description": "Local manager for dance-of-tal style Tal, Dance, Performer, and Act assets.",
  "scripts": {
    "start": "node server.js",
    "dot": "dot",
    "opencode": "OPENCODE_CONFIG_DIR=\"$HOME/.dot-studio/opencode\" ./.tools/lib/node_modules/dot-studio/node_modules/opencode-ai/bin/opencode serve --port 43120 --hostname 127.0.0.1 --log-level INFO",
    "studio": "dot-studio open . --port 43110 --opencode-url http://127.0.0.1:43120 --no-open < /dev/null",
    "studio:doctor": "dot-studio doctor . --verbose",
    "studio:patch-resize": "node scripts/patch-dot-studio-resize.js",
    "studio:commercial": "node scripts/run-commercial-studio.js",
    "local:stack": "node scripts/run-local-stack.js",
    "knolet:import": "node scripts/import-dot-workspace.js .dance-of-tal --out knolet.json",
    "test": "node --test",
    "mode:check": "node scripts/check-commercial-boundary.js",
    "commercial:check": "DANCEOFTAL_MODE=commercial node scripts/check-commercial-boundary.js",
    "production:check": "DANCEOFTAL_MODE=production node scripts/check-commercial-boundary.js"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
