# Copy this to your secret manager or local shell profile for commercial runs.
# Do not point commercial builds at the upstream DOT Supabase project.

DOT_SUPABASE_URL=https://auth.your-domain.example
DOT_SUPABASE_ANON_KEY=replace-with-your-public-anon-key
DANCEOFTAL_DATA_API_URL=https://api.your-domain.example

# Optional local development data roots owned by this product.
STUDIO_DIR=.dance-of-tal/commercial/studio-data
OPENCODE_CONFIG_DIR=.dance-of-tal/commercial/opencode

# Keep service ports explicit.
DOT_STUDIO_PORT=43110
OPENCODE_URL=http://127.0.0.1:43120
